# Auth.js v5 — required
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Microsoft Entra ID provider — required
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0

# Authorization (research.md D8) — comma-separated list of Entra group object IDs
# allowed to sign in. Empty / unset = all tenant users admitted.
ALLOWED_USER_GROUP_OBJECT_IDS=
# Single Entra group object ID whose members get the `admin` role.
ADMIN_GROUP_OBJECT_ID=

# Backend API base URL.
# - API_BASE_URL: server-only (used by RSC / route handlers / server actions).
# - NEXT_PUBLIC_API_BASE_URL: exposed to the browser; must be reachable via
#   the same internal ingress path as the server URL (or omitted if all
#   API calls happen on the server).
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=
