    "react-dom": "^19.0.0",
    "next-auth": "^5.0.0-beta.25",
    "@auth/core": "^0.37.0",
    "@ai-sdk/react": "^1.0.0",
    "ai": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "postcss": "^8.4.47",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.5",
    "lucide-react": "^0.468.0",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.3",
    "@radix-ui/react-dropdown-menu": "^2.1.3",
